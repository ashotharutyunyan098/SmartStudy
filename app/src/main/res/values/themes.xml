<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SmartStudy" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:editTextColor">@color/prussianBlue</item>
        <item name="android:textColorPrimary">@color/prussianBlue</item>
    </style>

    <style name="Theme.SmartStudy" parent="Base.Theme.SmartStudy" />

    <style name="CalcNumber">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/prussianBlue</item>
        <item name="android:backgroundTint">@color/creamWhite</item>
    </style>

    <style name="CalcOperator">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:backgroundTint">@color/smartBlue</item>
    </style>

    <style name="CalcScientific">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:backgroundTint">@color/regalNavy</item>
    </style>

    <style name="CalcEquals">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:backgroundTint">@color/smartBlue</item>
    </style>

</resources>