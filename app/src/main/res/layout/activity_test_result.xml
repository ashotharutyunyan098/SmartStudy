<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/white"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Test Complete!"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/prussianBlue"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="7/10"
        android:textSize="64sp"
        android:textStyle="bold"
        android:textColor="@color/smartBlue"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvStars"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⭐⭐⭐"
        android:textSize="48sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvResultMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Excellent work!"
        android:textSize="18sp"
        android:textColor="@color/coolSteel"
        android:gravity="center"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnTryAgain"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Try Again"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/smartBlue"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnBackToGrade"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Back to Grade"
        android:textSize="16sp"
        android:textColor="@color/prussianBlue"
        android:backgroundTint="@color/veryLightBlue"/>

</LinearLayout>