        android:layout_height="wrap_content"
        android:text="Mathematics"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/prussianBlue"
        android:paddingStart="24dp"
        android:paddingBottom="4dp"/>

